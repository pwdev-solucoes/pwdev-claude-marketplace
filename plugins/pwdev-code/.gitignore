# =============================================================================
# PWDEV-CODE Plugin - .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# IDE / Editor
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-workspace
*.sublime-project

# -----------------------------------------------------------------------------
# OS Generated
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# PWDEV-CODE Workspace Artifacts
# -----------------------------------------------------------------------------
# Session-specific artifacts (do not commit)
.planning/phases/
.planning/quick/
.planning/archive/
.planning/research/
.planning/codebase/

# Keep structure files
!.planning/STATE.md
!.planning/config.json
!.planning/templates/

# -----------------------------------------------------------------------------
# Security - NEVER commit these
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local
.env.development
.env.test
.env.production
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
id_rsa*
*.credentials
secrets.*
credentials.json
service-account*.json

# -----------------------------------------------------------------------------
# Dependencies
# -----------------------------------------------------------------------------
node_modules/
vendor/
.pnpm-store/
.yarn/
.npm/

# -----------------------------------------------------------------------------
# Build Output
# -----------------------------------------------------------------------------
dist/
build/
out/
.next/
.nuxt/
.output/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# -----------------------------------------------------------------------------
# Test & Coverage
# -----------------------------------------------------------------------------
coverage/
.nyc_output/
*.lcov
.coverage
htmlcov/

# -----------------------------------------------------------------------------
# Cache
# -----------------------------------------------------------------------------
.cache/
*.cache
.parcel-cache/
.turbo/
.eslintcache
.stylelintcache
*.tsbuildinfo

# -----------------------------------------------------------------------------
# Temporary
# -----------------------------------------------------------------------------
tmp/
temp/
*.tmp
*.temp
*.bak
*.backup

# -----------------------------------------------------------------------------
# MCP Server Backups
# -----------------------------------------------------------------------------
*.mcp.json.bak
mcp.json.bak
